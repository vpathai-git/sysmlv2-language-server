{
  "name": "sysml-server-workspace",
  "version": "0.1.0",
  "private": true,
  "license": "LGPL-3.0-or-later",
  "workspaces": [
    "packages/*",
    "extension/shim"
  ],
  "scripts": {
    "build": "npm run build -w @sysml/shim && npm run build -w @sysml/grammar && npm run build -w @sysml/core && npm run build -w @sysml/language-server",
    "test": "npm run test --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "esbuild": "^0.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.16"
  }
}
